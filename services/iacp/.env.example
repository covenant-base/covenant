REDIS_URL=redis://127.0.0.1:6379
IACP_PORT=8080
LOG_LEVEL=info
# Shared HMAC secret for session JWTs; must match apps/portal SESSION_SECRET.
SESSION_SECRET=
# Service-role bearer for POST /publish.
IACP_SERVICE_TOKEN=
# Base RPC. Unset disables optional chain validation.
COVENANT_BASE_RPC_URL=
# Override the deployed agent registry contract for local testing.
COVENANT_CONTRACT_AGENT_REGISTRY=
# Envelope freshness window: reject envelope `ts` older than this (ms, default 300000 = 5min).
IACP_ENVELOPE_MAX_AGE_MS=
# Clock-skew tolerance into the future (ms, default 30000 = 30s).
IACP_ENVELOPE_CLOCK_SKEW_MS=
# Per-agent publish rate limit. Shared across WS + REST. Defaults 20 burst / 5 msg/s sustained.
IACP_RL_BURST=
IACP_RL_SUSTAINED_PER_S=
# Per-socket inbound bandwidth cap (WS only, bytes). Defaults 262144 burst / 65536 bytes/s sustained.
IACP_BW_BURST_BYTES=
IACP_BW_SUSTAINED_BYTES_PER_S=
# Idle-bucket sweep interval (ms, default 30000).
IACP_RL_SWEEP_MS=
