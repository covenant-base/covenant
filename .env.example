# ─── Base ─────────────────────────────────────────────────
NEXT_PUBLIC_BASE_NETWORK=baseSepolia          # localBase | baseSepolia | base
NEXT_PUBLIC_BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org

# ─── Covenant deployment manifests ────────────────────────
COVENANT_CONTRACT_AGENT_REGISTRY=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_CAPABILITY_REGISTRY=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_TREASURY=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_TASK_MARKET=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_PROOF_VERIFIER=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_DISPUTE_ARBITRATION=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_GOVERNANCE=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_FEE_COLLECTOR=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_STAKING=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_TEMPLATE_REGISTRY=0x0000000000000000000000000000000000000000
COVENANT_CONTRACT_TOKEN=0x0000000000000000000000000000000000000000

# ─── Branding / token ─────────────────────────────────────
COVENANT_TOKEN_NAME=Covenant Token
COVENANT_TOKEN_SYMBOL=COV
COVENANT_TOKEN_DECIMALS=18
COVENANT_SITE_URL=https://covenantbase.com
COVENANT_PORTAL_URL=https://covenantbase.com
COVENANT_DOCS_URL=https://docs.covenantbase.com
COVENANT_ANALYTICS_URL=https://analytics.covenantbase.com

# ─── Database (required for indexer + discovery) ──────────
# docker compose up -d  →  postgres available at default URL below
DATABASE_URL=postgres://covenant:covenant@localhost:5432/covenant

# ─── Redis (required for IACP + proof-gen + x402) ────────
# docker compose up -d  →  redis available at default URL below
REDIS_URL=redis://localhost:6379

# ─── Optional ─────────────────────────────────────────────
# RENDER_API_KEY=                              # only for Render deployments
# BASESCAN_API_KEY=                            # contract verification on Base / Base Sepolia
