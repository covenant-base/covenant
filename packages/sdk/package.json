{
  "name": "@covenant/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Covenant Protocol on Base",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/covenant-base/covenant"
  },
  "homepage": "https://covenantbase.com",
  "keywords": [
    "base",
    "evm",
    "agent",
    "covenant",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "node ../../scripts/export-base-artifacts.mjs",
    "build": "pnpm run generate && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "echo skip",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@covenant/config": "workspace:*",
    "jose": "5.9.6",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  }
}
