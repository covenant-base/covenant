    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource/archivo-black": "^5.2.8",
    "@tanstack/react-query": "5.100.5",
    "jose": "5.9.6",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "three": "^0.184.0",
    "viem": "^2.48.4",
    "wagmi": "^3.6.4"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "4.1.14",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.184.0",
